# Copy to .env and adjust for production (optional for local dev)

# SECURITY: generate a long random value for production, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# MUST be false in production. True enables debug pages that leak internals.
DJANGO_DEBUG=true

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Full https origin(s) of your deployed site, comma-separated.
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example.com

# Session lifetime in seconds (default 8 hours).
DJANGO_SESSION_COOKIE_AGE=28800

# Quiz timing (seconds per question, enforced server-side)
QUIZ_QUESTION_SECONDS=60

# Registration rate limit per IP (raise on shared/campus NAT networks where many
# students share one public IP; lower to tighten anti-abuse protection).
REGISTER_MAX_PER_IP=10
REGISTER_THROTTLE_SECONDS=3600

# PlacementIQ — question generation & personalized tips (optional for local dev)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
