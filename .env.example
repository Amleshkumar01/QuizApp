# Copy to .env and fill in real values. NEVER commit the real .env.
# Generate a secret key:  python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── Django core ──
# MUST be false in production. True enables debug pages that leak internals.
DEBUG=true
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated hostnames Django will serve.
ALLOWED_HOSTS=localhost,127.0.0.1
# Full https origin(s) trusted for CSRF, comma-separated.
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com

# Public base URL of the deployed app (used for OAuth/redirect building).
APP_BASE_URL=http://127.0.0.1:3000

# ── Database (Supabase PostgreSQL — Session Pooler connection string) ──
# Supabase Dashboard → Project → Connect → "Session pooler".
# Format (placeholder — do NOT commit the real one):
#   postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# If DATABASE_URL is unset AND DEBUG=true, Django falls back to local SQLite.
# In production (DEBUG=false) DATABASE_URL is REQUIRED.
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# ── Supabase Auth (read from env only — never hardcode) ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_SECRET_KEY=your-service-role-secret-key

# ── App settings ──
# Session lifetime in seconds (default 8 hours).
DJANGO_SESSION_COOKIE_AGE=28800
# Quiz timing (seconds per question, enforced server-side).
QUIZ_QUESTION_SECONDS=60
# Registration rate limit per IP.
REGISTER_MAX_PER_IP=10
REGISTER_THROTTLE_SECONDS=3600

# ── OpenAI (optional; sample questions used if unset) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
